{
  "name": "@techfield/api",
  "version": "1.0.0",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "dev": "nest start --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "migration:generate": "typeorm-ts-node-commonjs -d src/database/data-source.ts migration:generate",
    "migration:run": "typeorm-ts-node-commonjs -d src/database/data-source.ts migration:run",
    "migration:revert": "typeorm-ts-node-commonjs -d src/database/data-source.ts migration:revert",
    "seed": "ts-node src/database/seeds/run-seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.490.0",
    "@aws-sdk/lib-storage": "^3.490.0",
    "@nestjs/common": "10.4.2",
    "@nestjs/config": "3.3.0",
    "@nestjs/core": "10.4.2",
    "@nestjs/jwt": "10.2.0",
    "@nestjs/passport": "10.0.3",
    "@nestjs/platform-express": "10.4.2",
    "@nestjs/schedule": "4.1.2",
    "@nestjs/typeorm": "10.0.2",
    "@react-pdf/renderer": "^4.5.1",
    "@sentry/node": "^8.0.0",
    "@sentry/profiling-node": "^8.0.0",
    "@techfield/types": "*",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "express": "4.21.2",
    "firebase-admin": "^12.0.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.11.3",
    "react": "^19.2.5",
    "reflect-metadata": "^0.1.12",
    "rxjs": "^7.8.1",
    "short-uuid": "^5.2.0",
    "twilio": "^5.0.0",
    "typeorm": "0.3.20",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "10.4.2",
    "@nestjs/testing": "10.4.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.5",
    "@types/passport-jwt": "^4.0.0",
    "@types/react": "^19.2.14",
    "@types/uuid": "^9.0.7",
    "ts-node": "^10.9.2",
    "typeorm-ts-node-commonjs": "*",
    "typescript": "^5.3.0"
  }
}
